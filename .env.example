# agentdesk — environment template. Copy to .env and fill in the ONE required secret.
# A verbatim copy of this file is a valid .env (verified against app/config.py):
# - model/threshold vars may be left BLANK — config.py's blank-env-means-default validator
#   covers exactly the vars left blank below;
# - everything else defaults in code and ships COMMENTED OUT here (uncomment AND fill to
#   override — a blank value for these would fail pydantic's int/float parsing, not default).

# --- required secret ---------------------------------------------------------------------
# The only credential the whole stack needs (agents, embeddings, evals, AND the nightly
# quality-suite judge — ADR-033 deliberately reuses it; in CI it lives as the Actions repo
# secret OPENAI_API_KEY, never in a file).
OPENAI_API_KEY=

# --- infrastructure ----------------------------------------------------------------------
# `itsm` is the DATABASE name, intentionally kept from the project's original working title
# (matches docker-compose.yml). Defaults point at the compose services on localhost.
DATABASE_URL=postgresql+psycopg://itsm:itsm@localhost:5432/itsm
REDIS_URL=redis://localhost:6379/0

# --- models (LiteLLM names; bare name -> OpenAI, "litellm/<provider>/<model>" elsewhere) ---
# Blank = code default. Eval floors and measured thresholds BIND to these models (ADR-026):
# change them and the committed baselines/floors stop being meaningful — re-measure first.
TRIAGE_MODEL=
# ^ default: gpt-5-mini
SPECIALIST_MODEL=
# ^ default: gpt-5-mini
EMBEDDING_MODEL=
# ^ default: text-embedding-3-small (must produce 1536-dim vectors — the schema's EMBED_DIM)
JUDGE_MODEL=
# ^ default: gpt-5 — the quality suite's LLM judge (ADR-033): deliberately a STRONGER
#   sibling of gpt-5-mini (a model grading its own family's outputs shows self-preference
#   bias). Changing it mid-series makes faithfulness/helpfulness means non-comparable.

# --- validated thresholds (blank = code default, same validator as the models) ------------
RETRIEVAL_REFUSAL_THRESHOLD=
# ^ default: 0.45 — stage-1 refusal gate (best cosine among retrieved chunks; ADR-017)
HITL_APPROVAL_THRESHOLD_USD=
# ^ default: 500.0 — orders above this need a human approval (ADR-020)

# --- code-default-only knobs (uncomment AND set a value to override; never leave blank) ---
# RETRIEVAL_TOP_K=5
# RRF_K=60
# SEMANTIC_CACHE_THRESHOLD=0.75      # measured, not vibed (ADR-023)
# SEMANTIC_CACHE_TTL_SECONDS=86400   # 24 h; ingest also invalidates by content hash (ADR-024)
# RESPONSE_CACHE_TTL_SECONDS=300
# APP_ENV=dev
# LOG_LEVEL=INFO

# --- CMDB graph backend (M9, ADR-037 — postgres default needs NO config; Neo4j optional) ---
# GRAPH_BACKEND=postgres             # "neo4j" needs the compose service + `python -m graph.sync_neo4j`
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=agentdesk           # dev default; mirrors docker-compose NEO4J_AUTH

# --- Slack integration (M8, ADR-038/039 — both tokens empty = Slack OFF, everything else runs) ---
# Setup steps + app manifest: SLACK_SETUP.md. The bot token posts replies (post_slack_message
# + the runner's fallback); the app token opens the Socket Mode WebSocket (runner only).
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_TRIGGER_EMOJI=
# ^ default: ticket — reacting with :ticket: (🎫) on any thread message triggers ingestion
# CHAT_API_URL=http://localhost:8000 # the API the Socket Mode runner posts to
# SLACK_SINK_FILE=                   # test seam (eval suite only): capture posts to a file

# --- MCP server (M8, ADR-040 — `make mcp`; connect per the README "MCP server" section) ---
MCP_TOKENS=
# ^ static bearer-token -> acting-user map, e.g. "my-secret-token=demo.user@corp.com"
#   (comma-separate multiple pairs; full multi-user auth is deliberately out of scope)
# MCP_HOST=127.0.0.1                 # loopback for local dev; 0.0.0.0 when deployed
# MCP_PORT=8090

# --- observability (M6 — unused until tracing.py is wired; empty keys must stay a no-op) ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=https://cloud.langfuse.com
# ^ default shown (uncomment and use https://us.cloud.langfuse.com for US-region keys;
#   don't leave it uncommented-but-blank — host has no blank-means-default validation)
