  "users": {
    "total": 50,
    "orgs": ["sales", "engineering", "finance", "hr"],
    "role_mix": "mostly employee; one manager per org (4); two it_agent (incl. the system/agent service account)",
    "anchors": [
      {"slug": "demo-user", "name": "Demo User", "email": "demo.user@corp.com", "org": "sales", "role": "employee", "note": "demo persona; owns exactly one MacBook Pro laptop asset"},
      {"slug": "sales-manager", "name": "Morgan Reyes", "email": "morgan.reyes@corp.com", "org": "sales", "role": "manager", "note": "HITL approver for demo.user's >$500 orders"},
      {"slug": "it-bot", "name": "IT Service Account", "email": "it.bot@corp.com", "org": "engineering", "role": "it_agent", "note": "author of system/agent ticket comments (e.g. dedup links)"}
    ]
  },

  "assets": {
    "total": 150,
    "per_user": "~3 on average (0-4); demo-user is pinned to exactly 1",
    "os_distribution": {"macos": "~40%", "windows": "~50%", "linux": "~10%"},
    "type_mix": ["laptop", "desktop", "monitor", "phone"],
    "invariant": "every asset's user_id is a real user; a ticket's asset_id (when set) belongs to that ticket's user (enforced by composite FK)",
    "anchors": [
      {"owner": "demo-user", "type": "laptop", "os": "macos", "model": "MacBook Pro 16 (2024)", "note": "the single asset that makes 'order me an IDE -> macOS variant' work"}
    ]
  },

  "ticket_clusters": [
    {"slug": "exchange-outage", "size": 6, "type": "incident", "category": "email", "priority": "high", "status": "open",
     "canonical_title": "Exchange outage - Sales team email down",
     "variant_titles": ["Can't send or receive email since this morning", "Outlook stuck on 'disconnected'", "Sales team not getting emails", "Email down for the whole Sales floor", "Mail not syncing - urgent, client emails delayed"],
     "reporters": "Sales-org users", "note": "primary dedup demo: 5 near-duplicates of 1 canonical open incident"},
    {"slug": "vpn-drops", "size": 5, "type": "incident", "category": "network", "priority": "medium", "status_mix": ["open", "in_progress"],
     "canonical_title": "VPN keeps disconnecting every few minutes",
     "variant_titles": ["VPN drops when I switch Wi-Fi", "Constantly getting kicked off the VPN", "VPN unstable since the update", "Can't stay connected to VPN from home"], "related_article": "vpn-troubleshoot"},
    {"slug": "slow-laptop", "size": 5, "type": "incident", "category": "hardware", "priority": "low", "status_mix": ["open", "in_progress", "resolved"],
     "canonical_title": "My laptop has become very slow",
     "variant_titles": ["Laptop takes 10 minutes to boot", "Everything is lagging on my machine", "Laptop slow after latest updates", "Fans spinning and laptop crawling"],
     "asset_link": "each ticket sets asset_id to a laptop owned by its reporter", "related_article": "laptop-slow"},
    {"slug": "printer-offline", "size": 4, "type": "incident", "category": "hardware", "priority": "low", "status_mix": ["open", "resolved"],
     "canonical_title": "3rd floor printer shows offline",
     "variant_titles": ["Can't print to the office printer", "Printer greyed out / offline", "Nothing prints from the shared printer"], "related_article": "printer-troubleshoot",
     "note": "generic offline printer — deliberately NOT the E-505 driver error (negative space)"}
  ],

  "ticket_distribution": {
    "clustered": 20,
    "remainder": 280,
    "by_category_mirrors_articles": {"accounts": "~20%", "software": "~20%", "hardware": "~15%", "network": "~15%", "email": "~15%", "other": "~15%"},
    "type_mix": {"incident": "~65%", "request": "~35%"},
    "status_mix": {"open": "~25%", "in_progress": "~20%", "resolved": "~35%", "closed": "~20%"},
    "priority_mix": {"low": "~35%", "medium": "~40%", "high": "~20%", "critical": "~5%"},
    "comments": "seed 1-3 ticket_comments on a subset (~40) of resolved/closed tickets; the it_agent service account authors dedup-link comments on the cluster canonicals"
  },

